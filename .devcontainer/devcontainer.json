 "name": "RAG Development Environment",
  "image": "frejanah/rag-codespace:latest",

  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python3",
        "python.analysis.extraPaths": [
          "/root/.local/lib/python3.11/site-packages",
          "/usr/local/lib/python3.11/site-packages"
        ]
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },

  "remoteUser": "root",

  "containerEnv": {
    "PATH": "/usr/local/bin:${containerEnv:PATH}",
    "PYTHONPATH": "/root/.local/lib/python3.11/site-packages:/usr/local/lib/python3.11/site-packages"
  },

  "forwardPorts": [8888, 8000],

  "portsAttributes": {
    "8888": {
      "label": "Jupyter",
      "onAutoForward": "notify"
    }
  }
}
